# AI Survey Software — Environment Variables
# Copy this file to .env and fill in your actual values
# ⚠️  NEVER commit .env to version control

# Google Gemini API Key (required for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# AssemblyAI API Key (required for voice transcription)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# JWT Secret for authentication (auto-generated if not set)
JWT_SECRET=your_secret_key_here

# Rate Limiting
RATE_LIMIT_RPM=120
RATE_LIMIT_AI_RPM=30

# Logging
LOG_LEVEL=INFO

# Email Notifications (optional — leave blank to use mailto: fallback)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI Survey Platform
SMTP_USE_TLS=true
